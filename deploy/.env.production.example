# ============================================================
# 复制为 deploy/.env 后填写（勿提交 Git）
# cp deploy/.env.production.example deploy/.env
# ============================================================

# ---------- 站点 ----------

HTTP_PORT=80
# 浏览器访问地址（先用 IP：http://47.xxx.xxx.xxx）
CORS_ORIGIN=http://your-ecs-public-ip

# ---------- MySQL（Docker 容器，与本地类似）----------
# backend 通过 compose 内网连接 DB_HOST=mysql，无需改 DB_HOST

DB_HOST=mysql
DB_PORT=3306
DB_NAME=rag_db
DB_USER=rag
DB_PASSWORD=change-me-db-password
MYSQL_ROOT_PASSWORD=change-me-root-password

# ---------- 鉴权 ----------

JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password

# ---------- 千问 / DashScope（必填）----------

QWEN_API_KEY=sk-xxxxxxxx

# ---------- 后端 ----------

PORT=3001
NODE_ENV=production

# 上传文件在 Docker volume uploads_data（ECS 磁盘）
# 勿 docker compose down -v
