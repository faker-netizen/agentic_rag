# ============================================================
# 复制为 deploy/.env 后填写（勿提交 Git）
# cp deploy/.env.production.example deploy/.env
# ============================================================

# ---------- 你在 ECS 上通常只需改这些 ----------

# 对外 HTTP 端口（默认 80；若 80 被占可改 8080）
HTTP_PORT=80

# 访问前端的完整 URL（HTTPS 填 https://你的域名）
CORS_ORIGIN=https://your-domain.com

# ---------- 数据库（推荐阿里云 RDS MySQL）----------

DB_HOST=rm-xxxxx.mysql.rds.aliyuncs.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=rag_db

# ---------- 鉴权（自行生成随机长字符串）----------

JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# 首次启动自动创建的管理员（登录 Web 用）
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=change-me-strong-password

# ---------- 千问 / DashScope（必填，RAG 与对话）----------

QWEN_API_KEY=sk-xxxxxxxx
# 可选
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_CHAT_MODEL=qwen-plus
# QWEN_EMBEDDING_MODEL=text-embedding-v4

# ---------- 后端运行时 ----------

PORT=3001
NODE_ENV=production

# HTTPS 反代后 refresh cookie 需 Secure（Nginx 终止 TLS 时保持 production 即可）
# COOKIE_SAMESITE=lax

# ---------- 文件存储 ----------

# 上传文件保存在 Docker volume uploads_data（ECS 磁盘），无需 OSS
# 勿执行 docker compose down -v，否则会删除已上传文件
