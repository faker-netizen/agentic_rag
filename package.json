{
  "name": "repo_d2c",
  "private": true,
  "scripts": {
    "dev:frontend": "pnpm -C apps/web dev",
    "dev:backend": "pnpm -C apps/backend dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test:e2e": "playwright test -c e2e/playwright.config.mts",
    "test:e2e:smoke": "playwright test -c e2e/playwright.config.mts --grep @smoke",
    "test:e2e:integration": "playwright test -c e2e/playwright.config.mts --grep @integration",
    "test:e2e:ui": "playwright test -c e2e/playwright.config.mts --ui",
    "prepare": "husky",
    "dev": "concurrently -n web,backend -c blue,green \"pnpm -C apps/web dev\" \"pnpm -C apps/backend dev\""
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.28.1"
}
